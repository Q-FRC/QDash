#include "BuildConfig.h"
#include <QObject>

Config BuildConfig;

Config::Config()
{
    // Name and copyright
    APPLICATION_NAME = "@QDASH_NAME@";
    ORGANIZATION_NAME = "@QDASH_ORG@";
    REPOSITORY = "@QDASH_REPO@";

    BUILD_PLATFORM = "@QDASH_BUILD_PLATFORM@";
    BUILD_DATE = "@QDASH_BUILD_TIMESTAMP@";

    GIT_COMMIT = "@QDASH_COMMIT@";
    GIT_TAG = "@QDASH_TAG@";
    GIT_REFSPEC = "@QDASH_REFSPEC@";

    // Assume that builds outside of Git repos are "stable"
    if (GIT_REFSPEC == QStringLiteral("GITDIR-NOTFOUND")
        || GIT_TAG == QStringLiteral("GITDIR-NOTFOUND"))
    {
        GIT_REFSPEC = "refs/heads/stable";
        GIT_TAG = "stable";
    }

    if (GIT_REFSPEC.startsWith("refs/heads/"))
    {
        VERSION_CHANNEL = GIT_REFSPEC;
        VERSION_CHANNEL.remove("refs/heads/");
    }
    else if (!GIT_COMMIT.isEmpty())
    {
        VERSION_CHANNEL = GIT_COMMIT.mid(0, 8);
    }
    else
    {
        VERSION_CHANNEL = "unknown";
    }
}

QString Config::buildInfo() const
{
    return "<p>Git: <a href=@QDASH_REPO@>@QDASH_REPO@</a></p>" +
       "<p>Built on @QDASH_BUILD_TIMESTAMP@ for @QDASH_BUILD_PLATFORM@.</p>" +
       "<p>QDash @QDASH_TAG@, commit @QDASH_COMMIT@, channel " + VERSION_CHANNEL + "</p>";
}
